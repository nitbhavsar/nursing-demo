<footer class="site-footer" id="contact">

  {# ── Main footer grid ──────────────────────────────────── #}
  <div class="footer-main">
    <div class="container">
      <div class="row g-5">

        {# Col 1 – Brand / About #}
        <div class="col-lg-4 col-md-6">
          <div class="footer-brand">
            <img src="{{ college.logo }}" alt="{{ college.name }}" class="footer-logo" />
            <h5 class="footer-brand__name">{{ college.name }}</h5>
            <p class="footer-brand__tagline">
              Nurturing compassionate, skilled nursing professionals through
              excellence in education and clinical training.
            </p>
            <address class="footer-address">
              <i class="fas fa-map-marker-alt"></i>
              <span>
                {{ college.address.line1 }},
                {{ college.address.line2 }},
                {{ college.address.area }},
                {{ college.address.district }} – {{ college.address.pincode }}
              </span>
            </address>
          </div>
        </div>

        {# Col 2 – Quick Links #}
        <div class="col-lg-2 col-md-6 col-6">
          <div class="footer-col">
            <h6 class="footer-col__heading">Quick Links</h6>
            <ul class="footer-links">
              <li><a href="/">Home</a></li>
              <li><a href="/about/">About Us</a></li>
              <li><a href="/courses/">Programmes</a></li>
              <li><a href="/faculty/">Faculty</a></li>
              <li><a href="/facilities/">Facilities</a></li>
              <li><a href="/gallery/">Gallery</a></li>
              <li><a href="/admission/">Admissions</a></li>
              <li><a href="/contact/">Contact</a></li>
            </ul>
          </div>
        </div>

        {# Col 3 – Programmes #}
        <div class="col-lg-2 col-md-6 col-6">
          <div class="footer-col">
            <h6 class="footer-col__heading">Programmes</h6>
            <ul class="footer-links">
              <li>
                <a href="/courses/bsc-nursing/">
                  B.Sc. Nursing
                  <em>4 Yrs · 60 Seats</em>
                </a>
              </li>
              <li>
                <a href="/courses/gnm/">
                  G.N.M.
                  <em>3 Yrs · 60 Seats</em>
                </a>
              </li>
              <li>
                <a href="/courses/anm/">
                  A.N.M.
                  <em>2 Yrs · 40 Seats</em>
                </a>
              </li>
              <li>
                <a href="/courses/post-basic/">
                  Post Basic B.Sc.
                  <em>2 Yrs · 50 Seats</em>
                </a>
              </li>
            </ul>
          </div>
        </div>

        {# Col 4 – Contact #}
        <div class="col-lg-4 col-md-6">
          <div class="footer-col">
            <h6 class="footer-col__heading">Get In Touch</h6>

            <ul class="footer-contact-list">
              <li>
                <span class="fci"><i class="fas fa-phone"></i></span>
                <span>
                  Admin:
                  <a href="tel:9723706156">97237 06156</a>
                </span>
              </li>
              <li>
                <span class="fci"><i class="fas fa-phone-volume"></i></span>
                <span>
                  Admissions:
                  <a href="tel:9723706169">97237 06169</a> /
                  <a href="tel:9723706181">81</a>
                </span>
              </li>
              <li>
                <span class="fci"><i class="fas fa-envelope"></i></span>
                <span>
                  <a href="mailto:{{ college.email }}">{{ college.email }}</a>
                </span>
              </li>
              <li>
                <span class="fci"><i class="fas fa-map-marker-alt"></i></span>
                <span>Piludara, Mehsana, Gujarat</span>
              </li>
            </ul>

            {# Social icons #}
            <div class="footer-social">
              <a href="#" class="footer-social__link" aria-label="Facebook">
                <i class="fab fa-facebook-f"></i>
              </a>
              <a href="#" class="footer-social__link" aria-label="Instagram">
                <i class="fab fa-instagram"></i>
              </a>
              <a href="#" class="footer-social__link" aria-label="YouTube">
                <i class="fab fa-youtube"></i>
              </a>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  {# ── Affiliations bar ──────────────────────────────────── #}
  <div class="footer-affiliations">
    <div class="container">
      <p class="footer-affiliations__label">Recognised &amp; Affiliated With</p>
      <div class="footer-affiliations__items">

        <div class="affil-item">
          <i class="fas fa-university"></i>
          <span>H.N.G.U.</span>
        </div>

        <div class="affil-divider"></div>

        <div class="affil-item">
          <i class="fas fa-certificate"></i>
          <span>Gujarat Nursing Council</span>
        </div>

        <div class="affil-divider"></div>

        <div class="affil-item">
          <i class="fas fa-user-nurse"></i>
          <span>Indian Nursing Council</span>
        </div>

        <div class="affil-divider"></div>

        <div class="affil-item">
          <i class="fas fa-building-columns"></i>
          <span>Govt. of Gujarat</span>
        </div>

      </div>
    </div>
  </div>

  {# ── Bottom bar ────────────────────────────────────────── #}
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom__inner">
        <p>© {{ currentYear }} {{ college.name }}. All rights reserved.</p>
        <p>Managed by <strong>Merchant Education Trust, Visnagar</strong></p>
      </div>
    </div>
  </div>

</footer>
