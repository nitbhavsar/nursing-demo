          <div class="inq-success" id="inqSuccess" style="display:none;">
            <div class="inq-success__icon"><i class="fas fa-check-circle"></i></div>
            <h4>Inquiry Sent Successfully!</h4>
            <p>Thank you for reaching out. Our admissions team will contact you within 24 hours.</p>
            <a href="tel:9723706169" class="btn-primary mt-3">
              <i class="fas fa-phone"></i> Call Us Now
            </a>
          </div>

