          {# Web3Forms – free, 250 submissions/month              #}
          {# Get your access key at web3forms.com (enter email)   #}
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="inq-form"
            id="inquiryForm"
          >
            {# Replace YOUR_ACCESS_KEY with key from web3forms.com #}
            <input type="hidden" name="access_key" value="bcc72a03-25a6-4c14-9f5c-6b6f0dde22e3">
            <input type="hidden" name="subject" value="New Admission Inquiry – Merchant Institute of Nursing">
            <input type="hidden" name="from_name" value="Merchant Institute of Nursing Website">
            <input type="checkbox" name="botcheck" style="display:none;">

            <div class="row g-3">

              <div class="col-md-6">
                <div class="form-group">
                  <label for="inq_name">Full Name <span>*</span></label>
                  <input
                    type="text"
