                <div class="form-group">
                  <label for="inq_course">Course Interested In <span>*</span></label>
                  <select id="inq_course" name="course" required>
                    <option value="" disabled selected>Select a program</option>
                    <option value="bsc-nursing">B.Sc. Nursing (4 Years)</option>
                    <option value="gnm">G.N.M. (3 Years)</option>
                    <option value="anm">A.N.M. (2 Years)</option>
                    <option value="post-basic">Post Basic B.Sc. (2 Years)</option>
                    <option value="not-sure">Not sure yet</option>
                  </select>
                </div>
              </div>

              <div class="col-md-6">
                <div class="form-group">
                  <label for="inq_city">City / Location</label>
                  <input
                    type="text"
                    id="inq_city"
                    name="city"
