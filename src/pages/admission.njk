              </div>

              <div class="col-md-6">
                <div class="form-group">
                  <label for="inq_phone">Phone Number <span>*</span></label>
                  <input
                    type="tel"
                    id="inq_phone"
                    name="phone"
                    placeholder="10-digit mobile number"
                    pattern="[0-9]{10}"
