<script>
(function () {
  const form       = document.getElementById('contactForm');
  if (!form) return;
  const successMsg = document.getElementById('contactSuccess');
  const submitBtn  = form.querySelector('.inq-submit-btn');
  const btnText    = submitBtn.querySelector('.btn-text');
  const btnLoading = submitBtn.querySelector('.btn-loading');

  // College WhatsApp number (with country code, no + or spaces)
  const WHATSAPP_NUMBER = '919924999319';

  function buildWhatsAppMessage() {
    const name    = document.getElementById('ct_name').value.trim();
    const phone   = document.getElementById('ct_phone').value.trim();
    const email   = document.getElementById('ct_email').value.trim();
    const subject = document.getElementById('ct_subject').value || 'Not specified';
    const message = document.getElementById('ct_message').value.trim();

    return `*New Inquiry – Merchant Institute of Nursing*

*Name:* ${name}
*Phone:* ${phone}
*Email:* ${email}
*Subject:* ${subject}

*Message:*
${message}`;
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    btnText.style.display    = 'none';
    btnLoading.style.display = 'inline-flex';
    submitBtn.disabled       = true;

    try {
      // 1️⃣ Submit to Web3Forms (email notification)
      const res  = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) });
      const json = await res.json();

      if (json.success) {
        // 2️⃣ Open WhatsApp with pre-filled message
        const waText = encodeURIComponent(buildWhatsAppMessage());
        const waURL  = `https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`;
        window.open(waURL, '_blank');

        // 3️⃣ Show success message
        form.style.display       = 'none';
        successMsg.style.display = 'block';
      } else { throw new Error(); }

    } catch {
      btnText.style.display    = 'inline-flex';
      btnLoading.style.display = 'none';
      submitBtn.disabled       = false;
      alert('Something went wrong. Please call us on 97237 06169.');
    }
  });
})();
</script>
