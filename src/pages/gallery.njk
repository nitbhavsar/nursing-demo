---
layout: layouts/base.njk
title: Gallery – Merchant Institute of Nursing
permalink: /gallery/
---

{# ── PAGE BANNER ───────────────────────────────────────────── #}
<section class="page-banner">
  <div class="banner-blob"></div>
  <div class="banner-bar"></div>
  <div class="container">
    <nav class="banner-breadcrumb" aria-label="breadcrumb">
      <a href="{{ '/' | url }}">Home</a>
      <i class="fas fa-chevron-right"></i>
      <span>Gallery</span>
    </nav>
    <span class="banner-eyebrow">Campus Life</span>
    <h1>Photo Gallery</h1>
    <p>A glimpse into our campus, laboratories, events and student life at Merchant Institute of Nursing.</p>
  </div>
</section>

{# ── GALLERY ───────────────────────────────────────────────── #}
<section class="section bg-white">
  <div class="container">

    {# Filter tabs #}
    <div class="gallery-filter" data-aos="fade-up">
      <button class="gf-btn active" data-filter="all">All</button>
      <button class="gf-btn" data-filter="anatomy">Anatomy Lab</button>
      <button class="gf-btn" data-filter="nutrition">Nutrition Lab</button>
      <button class="gf-btn" data-filter="campusactivity">Campus Activity</button>
    </div>
<div class="gallery-grid" id="galleryGrid">

  {% for item in gallery %}
  <div class="gallery-item" 
       data-category="{{ item.category }}" 
       data-aos="fade-up" 
       data-aos-delay="{{ loop.index0 * 60 }}">

    <div class="gi-wrap">
      <img src="{{ item.src | url }}" 
           alt="{{ item.caption }}" 
           loading="lazy" />

      <div class="gi-overlay">
        <div class="gi-overlay-content">
          <span class="gi-caption">{{ item.caption }}</span>
          <span class="gi-category">{{ item.categoryName }}</span>
        </div>

        <button class="gi-zoom" aria-label="View full image">
          <i class="fas fa-expand"></i>
        </button>
      </div>
    </div>

  </div>
  {% endfor %}

</div>

  </div>
</section>

{# ── LIGHTBOX ──────────────────────────────────────────────── #}
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" style="display:none;">
  <div class="lightbox-backdrop" id="lightboxBackdrop"></div>
  <div class="lightbox-inner">
    <button class="lb-close" id="lbClose" aria-label="Close"><i class="fas fa-times"></i></button>
    <button class="lb-prev" id="lbPrev" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
    <button class="lb-next" id="lbNext" aria-label="Next"><i class="fas fa-chevron-right"></i></button>
    <div class="lb-img-wrap">
      <img src="" alt="" id="lbImg" />
    </div>
    <div class="lb-caption">
      <span id="lbCaption"></span>
      <span id="lbCounter" class="lb-counter"></span>
    </div>
  </div>
</div>

<script src="{{ '/js/gallery.js' | url }}"></script>
